generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  image             String?
  githubLogin       String?
  githubAccessToken String?
  emailVerified     DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  connectedAccounts ConnectedAccount[]
  githubEvents      GitHubEvent[]
  calendarEvents    CalendarEvent[]
  tasks             Task[]
  digests           Digest[]

  // NextAuth required fields
  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ConnectedAccount {
  id           String    @id @default(cuid())
  userId       String
  provider     String // "google" or "todoist"
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  needsReauth  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model GitHubEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String // "commit" or "pull_request"
  repo      String
  title     String
  sha       String?
  stableKey String   // sha or "repo-eventAt" composite — used for idempotent upserts
  eventAt   DateTime
  syncedAt  DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stableKey])
  @@index([userId, eventAt])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  userId        String
  googleId      String
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  attendeeCount Int      @default(0)
  syncedAt      DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleId])
  @@index([userId, startTime])
}

model Task {
  id        String    @id @default(cuid())
  userId    String
  todoistId String
  title     String
  project   String?
  priority  String    @default("normal") // "normal", "high", "urgent"
  dueDate   DateTime?
  completed Boolean   @default(false)
  syncedAt  DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, todoistId])
  @@index([userId, dueDate])
}

model Digest {
  id              String   @id @default(cuid())
  userId          String
  summaryText     String
  contextSnapshot Json
  coverDate       DateTime @db.Date
  generatedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, coverDate])
}
